{
  "name": "automock-lite-backend",
  "version": "1.0.0",
  "private": true,
"scripts": {
  "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
  "build": "npx tsc",
  "start": "npx prisma generate && npx prisma db push && node dist/server.js",
  "prisma:generate": "npx prisma generate",
  "prisma:migrate": "npx prisma migrate dev --name init"
},
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "html-to-text": "^9.0.5",
    "mammoth": "^1.4.21",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.0.0",
    "pdf-parse": "^1.1.1",
    "prisma": "^5.0.0",
    "typescript": "^5.2.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/html-to-text": "^9.0.4",
    "@types/multer": "^2.1.0",
    "@types/pdf-parse": "^1.1.5"
  },
  "devDependencies": {
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0"
  }
}